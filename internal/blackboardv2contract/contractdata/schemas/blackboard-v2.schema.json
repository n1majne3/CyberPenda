{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://cyberpenda.local/schemas/blackboard-v2.schema.json",
  "$defs": {
    "blackboardKey": {
      "type": "string",
      "minLength": 1,
      "maxLength": 96,
      "pattern": "^[\\x20-\\x7e]+$",
      "x-max-utf8-bytes": 96
    },
    "semanticText": {
      "type": "string",
      "minLength": 1,
      "maxLength": 1024,
      "x-max-utf8-bytes": 1024
    },
    "conciseText": {
      "type": "string",
      "minLength": 1,
      "maxLength": 512,
      "x-max-utf8-bytes": 512
    },
    "nonEmptyText": {"type": "string", "minLength": 1},
    "version": {"type": "integer", "minimum": 1},
    "revision": {"type": "integer", "minimum": 0},
    "scopeStatus": {"enum": ["in_scope", "unknown", "out_of_scope"]},
    "recordType": {"enum": ["entity", "objective", "attempt", "fact", "finding", "solution", "evidence"]},
    "relationType": {"enum": ["about", "part_of", "tests", "produced", "evidences", "supports", "contradicts", "derived_from", "depends_on", "satisfies", "supersedes"]},
    "reasonRelationType": {"enum": ["supports", "contradicts", "depends_on"]},
    "ordinaryRelationType": {"enum": ["about", "part_of", "tests", "produced", "evidences", "derived_from", "satisfies"]},
    "mutableRelationType": {"enum": ["about", "part_of", "tests", "produced", "evidences", "supports", "contradicts", "derived_from", "depends_on", "satisfies"]},

    "entityRecord": {
      "type": "object",
      "additionalProperties": false,
      "required": ["status", "kind", "name", "scope_status"],
      "properties": {
        "status": {"const": "active"},
        "kind": {"$ref": "#/$defs/conciseText"},
        "name": {"$ref": "#/$defs/conciseText"},
        "locator": {"$ref": "#/$defs/conciseText"},
        "description": {"$ref": "#/$defs/conciseText"},
        "scope_status": {"$ref": "#/$defs/scopeStatus"},
        "credential_ref": {"$ref": "#/$defs/conciseText"}
      }
    },
    "objectiveRecord": {
      "description": "objective record: objective (required), status (open only)",
      "type": "object",
      "additionalProperties": false,
      "required": ["status", "objective"],
      "properties": {
        "status": {"const": "open"},
        "objective": {"$ref": "#/$defs/semanticText"}
      }
    },
    "attemptRecord": {
      "description": "attempt record: summary (required), status (open only)",
      "type": "object",
      "additionalProperties": false,
      "required": ["status", "summary"],
      "properties": {
        "status": {"const": "open"},
        "summary": {"$ref": "#/$defs/semanticText"}
      }
    },
    "factRecord": {
      "type": "object",
      "additionalProperties": false,
      "required": ["category", "summary", "confidence", "scope_status"],
      "properties": {
        "category": {"$ref": "#/$defs/conciseText"},
        "summary": {"$ref": "#/$defs/semanticText"},
        "body": {"$ref": "#/$defs/nonEmptyText"},
        "confidence": {"enum": ["tentative", "confirmed"]},
        "scope_status": {"$ref": "#/$defs/scopeStatus"}
      }
    },
    "findingInputRecord": {
      "type": "object",
      "additionalProperties": false,
      "required": ["status", "title"],
      "dependentRequired": {"cvss_version": ["cvss_vector"], "cvss_vector": ["cvss_version"]},
      "properties": {
        "status": {"enum": ["unconfirmed", "confirmed"]},
        "title": {"$ref": "#/$defs/conciseText"},
        "target": {"$ref": "#/$defs/conciseText"},
        "description": {"$ref": "#/$defs/semanticText"},
        "proof": {"$ref": "#/$defs/nonEmptyText"},
        "impact": {"$ref": "#/$defs/nonEmptyText"},
        "recommendation": {"$ref": "#/$defs/nonEmptyText"},
        "cvss_version": {"enum": ["3.1", "4.0"]},
        "cvss_vector": {"type": "string", "minLength": 1}
      },
      "allOf": [
        {"if": {"properties": {"status": {"const": "confirmed"}}}, "then": {"required": ["target", "proof", "impact", "recommendation", "cvss_version", "cvss_vector"]}}
      ]
    },
    "findingRecord": {
      "type": "object",
      "additionalProperties": false,
      "required": ["status", "title", "cvss_pending"],
      "dependentRequired": {"cvss_version": ["cvss_vector"], "cvss_vector": ["cvss_version"]},
      "properties": {
        "status": {"enum": ["unconfirmed", "confirmed"]},
        "title": {"$ref": "#/$defs/conciseText"},
        "target": {"$ref": "#/$defs/conciseText"},
        "description": {"$ref": "#/$defs/semanticText"},
        "proof": {"$ref": "#/$defs/nonEmptyText"},
        "impact": {"$ref": "#/$defs/nonEmptyText"},
        "recommendation": {"$ref": "#/$defs/nonEmptyText"},
        "cvss_version": {"enum": ["3.1", "4.0"]},
        "cvss_vector": {"type": "string", "minLength": 1},
        "severity": {"enum": ["none", "low", "medium", "high", "critical"]},
        "cvss_pending": {"type": "boolean"}
      },
      "allOf": [
        {"if": {"properties": {"status": {"const": "confirmed"}}}, "then": {"required": ["target", "proof", "impact", "recommendation", "cvss_version", "cvss_vector"]}}
      ]
    },
    "solutionRecord": {
      "type": "object",
      "additionalProperties": false,
      "required": ["status", "kind", "summary"],
      "properties": {
        "status": {"enum": ["candidate", "verified"]},
        "kind": {"enum": ["answer", "flag", "procedure"]},
        "summary": {"$ref": "#/$defs/semanticText"},
        "value": {"$ref": "#/$defs/nonEmptyText"},
        "verification_summary": {"$ref": "#/$defs/conciseText"}
      },
      "allOf": [
        {"if": {"properties": {"status": {"const": "verified"}}}, "then": {"required": ["verification_summary"]}},
        {"if": {"properties": {"status": {"const": "verified"}, "kind": {"enum": ["answer", "flag"]}}}, "then": {"required": ["value"]}}
      ]
    },
    "evidenceRecord": {
      "type": "object",
      "additionalProperties": false,
      "required": ["status", "artifact_type", "summary", "managed_path", "sha256", "size"],
      "properties": {
        "status": {"enum": ["available", "missing"]},
        "artifact_type": {"$ref": "#/$defs/conciseText"},
        "summary": {"$ref": "#/$defs/semanticText"},
        "media_type": {"$ref": "#/$defs/conciseText"},
        "source_path": {"type": "string"},
        "managed_path": {"type": "string", "minLength": 1},
        "sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
        "size": {"type": "integer", "minimum": 0},
        "captured_at": {"type": "string", "format": "date-time"}
      }
    },
    "evidenceInputRecord": {
      "type": "object", "additionalProperties": false,
      "required": ["status", "artifact_type", "summary", "source_path"],
      "properties": {"status": {"enum": ["available", "missing"]}, "artifact_type": {"$ref": "#/$defs/conciseText"}, "summary": {"$ref": "#/$defs/semanticText"}, "media_type": {"$ref": "#/$defs/conciseText"}, "source_path": {"type": "string", "minLength": 1}, "captured_at": {"type": "string", "format": "date-time"}}
    },
    "historicalEntityRecord": {
      "type": "object", "additionalProperties": false,
      "required": ["status", "kind", "name", "scope_status"],
      "properties": {"status": {"enum": ["active", "retired", "superseded"]}, "kind": {"$ref": "#/$defs/conciseText"}, "name": {"$ref": "#/$defs/conciseText"}, "locator": {"$ref": "#/$defs/conciseText"}, "description": {"$ref": "#/$defs/conciseText"}, "scope_status": {"$ref": "#/$defs/scopeStatus"}, "credential_ref": {"$ref": "#/$defs/conciseText"}}
    },
    "historicalObjectiveRecord": {
      "type": "object", "additionalProperties": false,
      "required": ["status", "objective"],
      "properties": {"status": {"enum": ["open", "resolved", "abandoned", "superseded"]}, "objective": {"$ref": "#/$defs/semanticText"}, "resolution_summary": {"$ref": "#/$defs/conciseText"}}
    },
    "historicalAttemptRecord": {
      "type": "object", "additionalProperties": false,
      "required": ["status", "summary"],
      "properties": {"status": {"enum": ["open", "succeeded", "failed", "blocked", "inconclusive", "interrupted"]}, "summary": {"$ref": "#/$defs/semanticText"}}
    },
    "historicalFactRecord": {
      "type": "object", "additionalProperties": false,
      "required": ["category", "summary", "confidence", "scope_status"],
      "properties": {"category": {"$ref": "#/$defs/conciseText"}, "summary": {"$ref": "#/$defs/semanticText"}, "body": {"$ref": "#/$defs/nonEmptyText"}, "confidence": {"enum": ["tentative", "confirmed", "deprecated"]}, "scope_status": {"$ref": "#/$defs/scopeStatus"}}
    },
    "historicalFindingRecord": {
      "type": "object", "additionalProperties": false,
      "required": ["status", "title", "cvss_pending"],
      "dependentRequired": {"cvss_version": ["cvss_vector"], "cvss_vector": ["cvss_version"]},
      "properties": {"status": {"enum": ["unconfirmed", "confirmed", "false_positive", "superseded"]}, "title": {"$ref": "#/$defs/conciseText"}, "target": {"$ref": "#/$defs/conciseText"}, "description": {"$ref": "#/$defs/semanticText"}, "proof": {"$ref": "#/$defs/nonEmptyText"}, "impact": {"$ref": "#/$defs/nonEmptyText"}, "recommendation": {"$ref": "#/$defs/nonEmptyText"}, "cvss_version": {"enum": ["3.1", "4.0"]}, "cvss_vector": {"type": "string", "minLength": 1}, "severity": {"enum": ["none", "low", "medium", "high", "critical"]}, "cvss_pending": {"type": "boolean"}, "resolution_summary": {"$ref": "#/$defs/conciseText"}},
      "allOf": [
        {"if": {"properties": {"status": {"const": "confirmed"}}}, "then": {"required": ["target", "proof", "impact", "recommendation", "cvss_version", "cvss_vector"]}}
      ]
    },
    "historicalSolutionRecord": {
      "type": "object", "additionalProperties": false,
      "required": ["status", "kind", "summary"],
      "properties": {"status": {"enum": ["candidate", "verified", "rejected", "superseded"]}, "kind": {"enum": ["answer", "flag", "procedure"]}, "summary": {"$ref": "#/$defs/semanticText"}, "value": {"$ref": "#/$defs/nonEmptyText"}, "verification_summary": {"$ref": "#/$defs/conciseText"}},
      "allOf": [
        {"if": {"properties": {"status": {"const": "verified"}}}, "then": {"required": ["verification_summary"]}},
        {"if": {"properties": {"status": {"const": "verified"}, "kind": {"enum": ["answer", "flag"]}}}, "then": {"required": ["value"]}}
      ]
    },
    "historicalEvidenceRecord": {
      "type": "object", "additionalProperties": false,
      "required": ["status", "artifact_type", "summary", "managed_path", "sha256", "size"],
      "properties": {"status": {"enum": ["available", "missing", "superseded"]}, "artifact_type": {"$ref": "#/$defs/conciseText"}, "summary": {"$ref": "#/$defs/semanticText"}, "media_type": {"$ref": "#/$defs/conciseText"}, "source_path": {"type": "string"}, "managed_path": {"type": "string", "minLength": 1}, "sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"}, "size": {"type": "integer", "minimum": 0}, "captured_at": {"type": "string", "format": "date-time"}}
    },

    "entityPartial": {
      "type": "object", "additionalProperties": false, "minProperties": 1,
      "properties": {"kind": {"$ref": "#/$defs/conciseText"}, "name": {"$ref": "#/$defs/conciseText"}, "locator": {"$ref": "#/$defs/conciseText"}, "description": {"$ref": "#/$defs/conciseText"}, "scope_status": {"$ref": "#/$defs/scopeStatus"}, "credential_ref": {"$ref": "#/$defs/conciseText"}}
    },
    "objectivePartial": {"type": "object", "additionalProperties": false, "minProperties": 1, "properties": {"objective": {"$ref": "#/$defs/semanticText"}}},
    "attemptPartial": {"type": "object", "additionalProperties": false, "minProperties": 1, "properties": {"summary": {"$ref": "#/$defs/semanticText"}}},
    "factPartial": {
      "type": "object", "additionalProperties": false, "minProperties": 1,
      "properties": {"category": {"$ref": "#/$defs/conciseText"}, "summary": {"$ref": "#/$defs/semanticText"}, "body": {"$ref": "#/$defs/nonEmptyText"}, "scope_status": {"$ref": "#/$defs/scopeStatus"}}
    },
    "findingPartial": {
      "type": "object", "additionalProperties": false, "minProperties": 1,
      "properties": {"title": {"$ref": "#/$defs/conciseText"}, "target": {"$ref": "#/$defs/conciseText"}, "description": {"$ref": "#/$defs/semanticText"}, "proof": {"$ref": "#/$defs/nonEmptyText"}, "impact": {"$ref": "#/$defs/nonEmptyText"}, "recommendation": {"$ref": "#/$defs/nonEmptyText"}, "cvss_version": {"enum": ["3.1", "4.0"]}, "cvss_vector": {"type": "string", "minLength": 1}}
    },
    "solutionPartial": {
      "type": "object", "additionalProperties": false, "minProperties": 1,
      "properties": {"kind": {"enum": ["answer", "flag", "procedure"]}, "summary": {"$ref": "#/$defs/semanticText"}, "value": {"$ref": "#/$defs/nonEmptyText"}, "verification_summary": {"$ref": "#/$defs/conciseText"}}
    },
    "evidencePartial": {
      "type": "object", "additionalProperties": false, "minProperties": 1,
      "properties": {"summary": {"$ref": "#/$defs/semanticText"}, "media_type": {"$ref": "#/$defs/conciseText"}, "captured_at": {"type": "string", "format": "date-time"}}
    },

    "snapshotEntity": {
      "type": "object", "additionalProperties": false,
      "required": ["version", "status", "kind", "name", "scope_status"],
      "properties": {"version": {"$ref": "#/$defs/version"}, "status": {"const": "active"}, "kind": {"$ref": "#/$defs/conciseText"}, "name": {"$ref": "#/$defs/conciseText"}, "locator": {"$ref": "#/$defs/conciseText"}, "description": {"$ref": "#/$defs/conciseText"}, "scope_status": {"$ref": "#/$defs/scopeStatus"}, "credential_ref": {"$ref": "#/$defs/conciseText"}}
    },
    "snapshotObjective": {
      "type": "object", "additionalProperties": false,
      "required": ["version", "status", "objective"],
      "properties": {"version": {"$ref": "#/$defs/version"}, "status": {"const": "open"}, "objective": {"$ref": "#/$defs/semanticText"}}
    },
    "snapshotAttempt": {
      "type": "object", "additionalProperties": false,
      "required": ["version", "status", "summary"],
      "properties": {"version": {"$ref": "#/$defs/version"}, "status": {"const": "open"}, "summary": {"$ref": "#/$defs/semanticText"}}
    },
    "snapshotFact": {
      "type": "object", "additionalProperties": false,
      "required": ["version", "category", "summary", "confidence", "scope_status"],
      "properties": {"version": {"$ref": "#/$defs/version"}, "category": {"$ref": "#/$defs/conciseText"}, "summary": {"$ref": "#/$defs/semanticText"}, "confidence": {"enum": ["tentative", "confirmed"]}, "scope_status": {"$ref": "#/$defs/scopeStatus"}}
    },
    "snapshotFinding": {
      "type": "object", "additionalProperties": false,
      "required": ["version", "status", "title", "cvss_pending"],
      "properties": {"version": {"$ref": "#/$defs/version"}, "status": {"enum": ["unconfirmed", "confirmed"]}, "title": {"$ref": "#/$defs/conciseText"}, "target": {"$ref": "#/$defs/conciseText"}, "description": {"$ref": "#/$defs/semanticText"}, "severity": {"enum": ["none", "low", "medium", "high", "critical"]}, "cvss_pending": {"type": "boolean"}},
      "allOf": [
        {"if": {"properties": {"status": {"const": "confirmed"}}}, "then": {"properties": {"cvss_pending": {"const": false}}}}
      ]
    },
    "snapshotSolution": {
      "type": "object", "additionalProperties": false,
      "required": ["version", "status", "kind", "summary"],
      "properties": {"version": {"$ref": "#/$defs/version"}, "status": {"enum": ["candidate", "verified"]}, "kind": {"enum": ["answer", "flag", "procedure"]}, "summary": {"$ref": "#/$defs/semanticText"}, "value": {"$ref": "#/$defs/nonEmptyText"}, "verification_summary": {"$ref": "#/$defs/conciseText"}},
      "allOf": [
        {"if": {"properties": {"status": {"const": "verified"}}}, "then": {"required": ["verification_summary"]}},
        {"if": {"properties": {"status": {"const": "verified"}, "kind": {"enum": ["answer", "flag"]}}}, "then": {"required": ["value"]}}
      ]
    },
    "snapshotEvidence": {
      "type": "object", "additionalProperties": false,
      "required": ["version", "status", "artifact_type", "summary"],
      "properties": {"version": {"$ref": "#/$defs/version"}, "status": {"enum": ["available", "missing"]}, "artifact_type": {"$ref": "#/$defs/conciseText"}, "summary": {"$ref": "#/$defs/semanticText"}, "media_type": {"$ref": "#/$defs/conciseText"}, "captured_at": {"type": "string", "format": "date-time"}}
    },
    "snapshotWork": {
      "type": "object", "additionalProperties": false,
      "properties": {
        "objectives": {"type": "object", "minProperties": 1, "propertyNames": {"$ref": "#/$defs/blackboardKey"}, "additionalProperties": {"$ref": "#/$defs/snapshotObjective"}},
        "attempts": {"type": "object", "minProperties": 1, "propertyNames": {"$ref": "#/$defs/blackboardKey"}, "additionalProperties": {"$ref": "#/$defs/snapshotAttempt"}}
      }
    },
    "snapshotKnowledge": {
      "type": "object", "additionalProperties": false,
      "properties": {
        "entities": {"type": "object", "minProperties": 1, "propertyNames": {"$ref": "#/$defs/blackboardKey"}, "additionalProperties": {"$ref": "#/$defs/snapshotEntity"}},
        "facts": {"type": "object", "minProperties": 1, "propertyNames": {"$ref": "#/$defs/blackboardKey"}, "additionalProperties": {"$ref": "#/$defs/snapshotFact"}},
        "findings": {"type": "object", "minProperties": 1, "propertyNames": {"$ref": "#/$defs/blackboardKey"}, "additionalProperties": {"$ref": "#/$defs/snapshotFinding"}},
        "solutions": {"type": "object", "minProperties": 1, "propertyNames": {"$ref": "#/$defs/blackboardKey"}, "additionalProperties": {"$ref": "#/$defs/snapshotSolution"}},
        "evidence": {"type": "object", "minProperties": 1, "propertyNames": {"$ref": "#/$defs/blackboardKey"}, "additionalProperties": {"$ref": "#/$defs/snapshotEvidence"}}
      },
      "not": {"required": ["findings", "solutions"]}
    },
    "relationshipTuple": {
      "oneOf": [
        {
          "type": "array", "minItems": 3, "maxItems": 3,
          "prefixItems": [{"$ref": "#/$defs/blackboardKey"}, {"enum": ["about", "part_of", "tests", "produced", "evidences", "derived_from", "satisfies", "supersedes"]}, {"$ref": "#/$defs/blackboardKey"}],
          "items": false
        },
        {
          "type": "array", "minItems": 3, "maxItems": 4,
          "prefixItems": [{"$ref": "#/$defs/blackboardKey"}, {"$ref": "#/$defs/reasonRelationType"}, {"$ref": "#/$defs/blackboardKey"}, {"$ref": "#/$defs/conciseText"}],
          "items": false
        }
      ]
    },
    "runtimeSnapshot": {
      "type": "object", "additionalProperties": false,
      "required": ["schema", "semantics", "revision", "work", "knowledge", "relations"],
      "properties": {
        "schema": {"const": "runtime-blackboard/v2"},
        "semantics": {"const": "work is active; knowledge is current; history and details are available by key"},
        "revision": {"$ref": "#/$defs/revision"},
        "work": {"$ref": "#/$defs/snapshotWork"},
        "knowledge": {"$ref": "#/$defs/snapshotKnowledge"},
        "relations": {"type": "array", "items": {"$ref": "#/$defs/relationshipTuple"}}
      }
    },

    "currentDetail": {
      "type": "object", "additionalProperties": false,
      "required": ["schema", "revision", "key", "type", "version", "record", "relationships"],
      "properties": {
        "schema": {"const": "blackboard-record/v2"},
        "revision": {"$ref": "#/$defs/revision"},
        "key": {"$ref": "#/$defs/blackboardKey"},
        "type": {"$ref": "#/$defs/recordType"},
        "version": {"$ref": "#/$defs/version"},
        "record": {"type": "object"},
        "relationships": {"type": "array", "items": {"$ref": "#/$defs/relationshipTuple"}},
        "sync": {"$ref": "#/$defs/syncAttachment"}
      },
      "allOf": [
        {"if": {"properties": {"type": {"const": "entity"}}}, "then": {"properties": {"record": {"$ref": "#/$defs/entityRecord"}}}},
        {"if": {"properties": {"type": {"const": "objective"}}}, "then": {"properties": {"record": {"$ref": "#/$defs/objectiveRecord"}}}},
        {"if": {"properties": {"type": {"const": "attempt"}}}, "then": {"properties": {"record": {"$ref": "#/$defs/attemptRecord"}}}},
        {"if": {"properties": {"type": {"const": "fact"}}}, "then": {"properties": {"record": {"$ref": "#/$defs/factRecord"}}}},
        {"if": {"properties": {"type": {"const": "finding"}}}, "then": {"properties": {"record": {"$ref": "#/$defs/findingRecord"}}}},
        {"if": {"properties": {"type": {"const": "solution"}}}, "then": {"properties": {"record": {"$ref": "#/$defs/solutionRecord"}}}},
        {"if": {"properties": {"type": {"const": "evidence"}}}, "then": {"properties": {"record": {"$ref": "#/$defs/evidenceRecord"}}}}
      ]
    },
    "recordHistoryItem": {
      "type": "object", "additionalProperties": false,
      "required": ["kind", "key", "version", "type", "record"],
      "properties": {"kind": {"const": "record"}, "key": {"$ref": "#/$defs/blackboardKey"}, "version": {"$ref": "#/$defs/version"}, "type": {"$ref": "#/$defs/recordType"}, "record": {"type": "object"}},
      "allOf": [
        {"if": {"properties": {"type": {"const": "entity"}}}, "then": {"properties": {"record": {"$ref": "#/$defs/historicalEntityRecord"}}}},
        {"if": {"properties": {"type": {"const": "objective"}}}, "then": {"properties": {"record": {"$ref": "#/$defs/historicalObjectiveRecord"}}}},
        {"if": {"properties": {"type": {"const": "attempt"}}}, "then": {"properties": {"record": {"$ref": "#/$defs/historicalAttemptRecord"}}}},
        {"if": {"properties": {"type": {"const": "fact"}}}, "then": {"properties": {"record": {"$ref": "#/$defs/historicalFactRecord"}}}},
        {"if": {"properties": {"type": {"const": "finding"}}}, "then": {"properties": {"record": {"$ref": "#/$defs/historicalFindingRecord"}}}},
        {"if": {"properties": {"type": {"const": "solution"}}}, "then": {"properties": {"record": {"$ref": "#/$defs/historicalSolutionRecord"}}}},
        {"if": {"properties": {"type": {"const": "evidence"}}}, "then": {"properties": {"record": {"$ref": "#/$defs/historicalEvidenceRecord"}}}}
      ]
    },
    "relationshipHistoryItem": {
      "oneOf": [
        {
          "type": "object", "additionalProperties": false,
          "required": ["kind", "version", "from", "relation", "to"],
          "properties": {"kind": {"const": "relationship"}, "version": {"$ref": "#/$defs/version"}, "from": {"$ref": "#/$defs/blackboardKey"}, "relation": {"$ref": "#/$defs/reasonRelationType"}, "to": {"$ref": "#/$defs/blackboardKey"}, "reason": {"$ref": "#/$defs/conciseText"}}
        },
        {
          "type": "object", "additionalProperties": false,
          "required": ["kind", "version", "from", "relation", "to"],
          "properties": {"kind": {"const": "relationship"}, "version": {"$ref": "#/$defs/version"}, "from": {"$ref": "#/$defs/blackboardKey"}, "relation": {"enum": ["about", "part_of", "tests", "produced", "evidences", "derived_from", "satisfies", "supersedes"]}, "to": {"$ref": "#/$defs/blackboardKey"}}
        }
      ]
    },
    "historyItem": {"oneOf": [{"$ref": "#/$defs/recordHistoryItem"}, {"$ref": "#/$defs/relationshipHistoryItem"}]},
    "semanticHistory": {
      "type": "object", "additionalProperties": false,
      "required": ["schema", "revision", "key", "items"],
      "properties": {
        "schema": {"const": "semantic-history/v2"},
        "revision": {"$ref": "#/$defs/revision"},
        "key": {"$ref": "#/$defs/blackboardKey"},
        "items": {"type": "array", "items": {"$ref": "#/$defs/historyItem"}},
        "next_cursor": {"type": "string", "minLength": 1},
        "sync": {"$ref": "#/$defs/syncAttachment"}
      }
    },
    "readRequest": {
      "type": "object", "additionalProperties": false, "required": ["key"],
      "properties": {"key": {"$ref": "#/$defs/blackboardKey"}}
    },
    "historyRequest": {
      "type": "object", "additionalProperties": false, "required": ["key"],
      "properties": {"key": {"$ref": "#/$defs/blackboardKey"}, "cursor": {"type": "string", "minLength": 1}, "limit": {"type": "integer", "minimum": 1, "maximum": 100, "default": 20}}
    },

    "createChange": {
      "description": "create requires key, type, and record; node types such as objective and attempt belong in type, never op",

{
  "openapi": "3.1.0",
  "info": {
    "title": "CyberPenda Project Interface",
    "version": "1.0.0",
    "description": "Version 1 graph Blackboard transport contract. Evolution is additive within v1; breaking changes require a new protocol and document version."
  },
  "paths": {
    "/api/projects/{project_id}/blackboard/mutations": {
      "post": {
        "operationId": "applyBlackboardMutationV1",
        "summary": "Apply one atomic graph mutation batch",
        "security": [{"continuationGrant": []}, {"operatorBearer": []}],
        "parameters": [{"$ref": "#/components/parameters/ProjectID"}],
        "requestBody": {
          "required": true,
          "content": {"application/json": {"schema": {"$ref": "#/components/schemas/ApplyMutationV1"}}}
        },
        "responses": {
          "200": {"description": "Applied, exact replay, or no-op", "headers": {"Cache-Control": {"schema": {"const": "no-store"}}}, "content": {"application/json": {"schema": {"$ref": "#/components/schemas/ApplyMutationResultV1"}}}},
          "400": {"$ref": "#/components/responses/Error"},
          "401": {"$ref": "#/components/responses/Error"},
          "403": {"$ref": "#/components/responses/Error"},
          "404": {"$ref": "#/components/responses/Error"},
          "409": {"$ref": "#/components/responses/Error"},
          "422": {"$ref": "#/components/responses/Error"},
          "500": {"$ref": "#/components/responses/Error"},
          "503": {"$ref": "#/components/responses/RetryableError"}
        }
      }
    },
    "/api/projects/{project_id}/blackboard/records:resolve": {
      "post": {
        "operationId": "resolveBlackboardRecordsV1",
        "summary": "Resolve current graph records for optimistic concurrency",
        "security": [{"continuationGrant": []}, {"operatorBearer": []}],
        "parameters": [{"$ref": "#/components/parameters/ProjectID"}],
        "requestBody": {
          "required": true,
          "content": {"application/json": {"schema": {"$ref": "#/components/schemas/ResolveRecordsV1"}}}
        },
        "responses": {
          "200": {"description": "Resolved records and missing references", "content": {"application/json": {"schema": {"$ref": "#/components/schemas/ResolveRecordsResultV1"}}}},
          "400": {"$ref": "#/components/responses/Error"},
          "401": {"$ref": "#/components/responses/Error"},
          "403": {"$ref": "#/components/responses/Error"},
          "404": {"$ref": "#/components/responses/Error"},
          "500": {"$ref": "#/components/responses/Error"},
          "503": {"$ref": "#/components/responses/RetryableError"}
        }
      }
    },
    "/api/projects/{project_id}/blackboard/evidence:retain": {
      "post": {
        "operationId": "retainBlackboardEvidenceV1",
        "summary": "Retain a confined Evidence payload and represent it in the graph",
        "security": [{"continuationGrant": []}, {"operatorBearer": []}],
        "parameters": [{"$ref": "#/components/parameters/ProjectID"}],
        "requestBody": {
          "required": true,
          "content": {"application/json": {"schema": {"$ref": "#/components/schemas/RetainEvidenceV1"}}}
        },
        "responses": {
          "200": {"description": "Retained or exact replay", "headers": {"Cache-Control": {"schema": {"const": "no-store"}}}, "content": {"application/json": {"schema": {"$ref": "#/components/schemas/RetainEvidenceResultV1"}}}},
          "400": {"$ref": "#/components/responses/Error"},
          "401": {"$ref": "#/components/responses/Error"},
          "403": {"$ref": "#/components/responses/Error"},
          "404": {"$ref": "#/components/responses/Error"},
          "409": {"$ref": "#/components/responses/Error"},
          "422": {"$ref": "#/components/responses/Error"},
          "500": {"$ref": "#/components/responses/Error"},
          "503": {"$ref": "#/components/responses/RetryableError"}
        }
      }
    },
    "/api/projects/{project_id}/blackboard/attempts:checkpoint": {
      "post": {
        "operationId": "checkpointBlackboardAttemptV1",
        "summary": "Append a durable Attempt checkpoint Event and update its summary",
        "security": [{"continuationGrant": []}],
        "parameters": [{"$ref": "#/components/parameters/ProjectID"}],
        "requestBody": {
          "required": true,
          "content": {"application/json": {"schema": {"$ref": "#/components/schemas/CheckpointAttemptV1"}}}
        },
        "responses": {
          "200": {"description": "Checkpointed or exact replay", "headers": {"Cache-Control": {"schema": {"const": "no-store"}}}, "content": {"application/json": {"schema": {"type": "object"}}}},
          "400": {"$ref": "#/components/responses/Error"},
          "401": {"$ref": "#/components/responses/Error"},
          "403": {"$ref": "#/components/responses/Error"},
          "404": {"$ref": "#/components/responses/Error"},
          "409": {"$ref": "#/components/responses/Error"},
          "422": {"$ref": "#/components/responses/Error"},
          "500": {"$ref": "#/components/responses/Error"},
          "503": {"$ref": "#/components/responses/RetryableError"}
        }
      }
    },
    "/api/projects/{project_id}/tasks/{task_id}/continuations/{continuation_id}:finish": {
      "post": {
        "operationId": "finishContinuationV1",
        "summary": "Store the Continuation Task Summary and close later Runtime writes",
        "security": [{"continuationGrant": []}],
        "parameters": [
          {"$ref": "#/components/parameters/ProjectID"},
          {"name": "task_id", "in": "path", "required": true, "schema": {"type": "string", "minLength": 1}},
          {"name": "continuation_id", "in": "path", "required": true, "schema": {"type": "string", "minLength": 1}}
        ],
        "requestBody": {
          "required": true,
          "content": {"application/json": {"schema": {"$ref": "#/components/schemas/FinishContinuationV1"}}}
        },
        "responses": {
          "200": {"description": "Finished or exact replay", "headers": {"Cache-Control": {"schema": {"const": "no-store"}}}, "content": {"application/json": {"schema": {"type": "object"}}}},
          "400": {"$ref": "#/components/responses/Error"},
          "401": {"$ref": "#/components/responses/Error"},
          "403": {"$ref": "#/components/responses/Error"},
          "404": {"$ref": "#/components/responses/Error"},
          "409": {"$ref": "#/components/responses/Error"},
          "422": {"$ref": "#/components/responses/Error"},
          "500": {"$ref": "#/components/responses/Error"},
          "503": {"$ref": "#/components/responses/RetryableError"}
        }
      }
    },
    "/api/projects/{project_id}/blackboard/runtime-graph": {
      "get": {
        "operationId": "getCurrentRuntimeGraphV1",
        "summary": "Read the full current CanonicalMainGraphV1",
        "security": [{"continuationGrant": []}, {"operatorBearer": []}],
        "parameters": [
          {"$ref": "#/components/parameters/ProjectID"},
          {"name": "If-None-Match", "in": "header", "schema": {"type": "string"}}
        ],
        "responses": {
          "200": {"description": "Full current graph", "headers": {"ETag": {"required": true, "schema": {"type": "string"}}, "Cache-Control": {"schema": {"const": "private, no-cache"}}}, "content": {"application/json": {"schema": {"$ref": "#/components/schemas/CurrentGraphResultV1"}}}},
          "304": {"description": "Projection ETag unchanged"},
          "400": {"$ref": "#/components/responses/Error"},
          "401": {"$ref": "#/components/responses/Error"},
          "403": {"$ref": "#/components/responses/Error"},
          "404": {"$ref": "#/components/responses/Error"},
          "500": {"$ref": "#/components/responses/Error"},
          "503": {"$ref": "#/components/responses/RetryableError"}
        }
      }
    }
  },
  "components": {
    "securitySchemes": {
      "continuationGrant": {"type": "http", "scheme": "bearer", "description": "Daemon-issued Continuation Interface Grant"},
      "operatorBearer": {"type": "http", "scheme": "bearer", "description": "Daemon operator credential; operator identity is resolved by the trusted daemon"}
    },
    "parameters": {
      "ProjectID": {"name": "project_id", "in": "path", "required": true, "schema": {"type": "string", "minLength": 1}}
    },
    "responses": {
      "Error": {"description": "Structured project-interface failure", "content": {"application/json": {"schema": {"$ref": "#/components/schemas/ErrorEnvelopeV1"}}}},
      "RetryableError": {"description": "Retryable local storage failure", "headers": {"Retry-After": {"required": true, "schema": {"type": "integer", "minimum": 1}}}, "content": {"application/json": {"schema": {"$ref": "#/components/schemas/ErrorEnvelopeV1"}}}}
    },
    "schemas": {
      "ApplyMutationV1": {
        "type": "object",
        "additionalProperties": false,
        "required": ["protocol_version", "batch"],
        "properties": {
          "protocol_version": {"const": 1},
          "batch": {"$ref": "#/components/schemas/MutationBatchV1"},
          "source_event_ids_by_op": {"type": "object", "additionalProperties": {"type": "array", "maxItems": 32, "items": {"type": "string", "minLength": 1}}}
        }
      },
      "MutationBatchV1": {
        "type": "object",
        "additionalProperties": false,
        "required": ["schema_version", "idempotency_key", "operations"],
        "properties": {
          "schema_version": {"const": 1},
          "idempotency_key": {"type": "string", "minLength": 1},
          "operations": {"type": "array", "minItems": 1, "maxItems": 128, "items": {"type": "object"}}
        }
      },
      "ResolveRecordsV1": {
        "type": "object",
        "additionalProperties": false,
        "required": ["protocol_version", "nodes"],
        "properties": {
          "protocol_version": {"const": 1},
          "nodes": {"type": "array", "maxItems": 100, "items": {"$ref": "#/components/schemas/NodeLookupV1"}},
          "edge_ids": {"type": "array", "maxItems": 100, "items": {"type": "string", "minLength": 1}}
        }
      },
      "RetainEvidenceV1": {
        "type": "object",
        "additionalProperties": false,
        "required": ["protocol_version", "idempotency_key", "stable_key", "artifact_type", "source_path", "summary"],
        "properties": {
          "protocol_version": {"const": 1},
          "idempotency_key": {"type": "string", "minLength": 1},
          "stable_key": {"type": "string", "minLength": 1},
          "expected_version": {"type": ["integer", "null"], "minimum": 1},
          "artifact_type": {"type": "string", "minLength": 1},
          "media_type": {"type": "string"},
          "source_path": {"type": "string", "minLength": 1},
          "summary": {"type": "string", "minLength": 1},
          "captured_at": {"type": "string", "format": "date-time"},
          "produced_by_attempt": {"$ref": "#/components/schemas/NodeLookupV1"},
          "links": {"type": "array", "items": {"type": "object", "additionalProperties": false, "required": ["edge_type", "to"], "properties": {"edge_type": {"enum": ["evidences", "about"]}, "to": {"$ref": "#/components/schemas/NodeLookupV1"}}}}
        }
      },
      "CheckpointAttemptV1": {
        "type": "object",
        "additionalProperties": false,
        "required": ["protocol_version", "idempotency_key", "attempt", "expected_version", "summary"],
        "properties": {
          "protocol_version": {"const": 1},
          "idempotency_key": {"type": "string", "minLength": 1},
          "attempt": {"$ref": "#/components/schemas/NodeLookupV1"},
          "expected_version": {"type": "integer", "minimum": 1},
          "summary": {"type": "string", "minLength": 1}
        }
      },
      "FinishContinuationV1": {
        "type": "object",
        "additionalProperties": false,
        "required": ["protocol_version", "idempotency_key", "summary"],
        "properties": {
          "protocol_version": {"const": 1},
          "idempotency_key": {"type": "string", "minLength": 1},
          "summary": {"type": "string", "minLength": 1},
          "objective_outcome": {
            "type": "object",
            "additionalProperties": false,
            "required": ["objective", "status"],
            "properties": {
              "objective": {"$ref": "#/components/schemas/NodeLookupV1"},
              "status": {"enum": ["supported", "contradicted", "inconclusive", "blocked"]},
              "supporting_node_refs": {"type": "array", "items": {"$ref": "#/components/schemas/ObjectiveOutcomeSupportingRefV1"}}
            }
          }
        }
      },
      "NodeLookupV1": {
        "type": "object",
        "additionalProperties": false,
        "properties": {"id": {"type": "string"}, "node_type": {"type": "string"}, "stable_key": {"type": "string"}},
        "oneOf": [{"required": ["id"]}, {"required": ["node_type", "stable_key"]}]
      },
      "ObjectiveOutcomeSupportingRefV1": {
        "description": "An ID must resolve to a Project Fact, Finding, or Evidence Artifact; keyed references are restricted to those node types.",
        "allOf": [
          {"$ref": "#/components/schemas/NodeLookupV1"},
          {"type": "object", "properties": {"node_type": {"enum": ["project_fact", "finding", "evidence_artifact"]}}}
        ]
      },
      "ApplyMutationResultV1": {"allOf": [{"$ref": "#/components/schemas/SuccessEnvelopeV1"}, {"type": "object", "required": ["result"], "properties": {"request_kind": {"const": "apply"}, "result": {"type": "object"}}}]},
      "RetainEvidenceResultV1": {"allOf": [{"$ref": "#/components/schemas/SuccessEnvelopeV1"}, {"type": "object", "required": ["result"], "properties": {"request_kind": {"const": "retain_evidence"}, "result": {"type": "object", "required": ["node", "edges", "managed_path", "sha256", "size_bytes", "mutation"]}}}]},
      "ResolveRecordsResultV1": {"allOf": [{"$ref": "#/components/schemas/SuccessEnvelopeV1"}, {"type": "object", "properties": {"request_kind": {"const": "resolve_records"}, "nodes": {"type": "array"}, "edges": {"type": "array"}, "missing": {"type": "array"}, "missing_edges": {"type": "array"}}}]},
      "CurrentGraphResultV1": {"allOf": [{"$ref": "#/components/schemas/SuccessEnvelopeV1"}, {"type": "object", "required": ["result"], "properties": {"request_kind": {"const": "current_graph"}, "result": {"type": "object", "required": ["renderer_version", "projection_hash", "projection_bytes", "estimated_tokens", "graph"]}}}]},
      "SuccessEnvelopeV1": {"type": "object", "required": ["protocol_version", "request_kind", "project_id", "observed_graph_revision"], "properties": {"protocol_version": {"const": 1}, "request_kind": {"type": "string"}, "project_id": {"type": "string"}, "observed_graph_revision": {"type": "integer", "minimum": 0}}},
      "ErrorEnvelopeV1": {"type": "object", "additionalProperties": false, "required": ["error"], "properties": {"error": {"$ref": "#/components/schemas/ProjectInterfaceErrorV1"}}},
      "ProjectInterfaceErrorV1": {
        "type": "object",
        "additionalProperties": false,
        "required": ["protocol_version", "code", "message", "retryable", "request_id"],
        "properties": {
          "protocol_version": {"const": 1}, "code": {"type": "string"}, "message": {"type": "string"},
          "operation_index": {"type": "integer", "minimum": 0}, "op_id": {"type": "string"}, "path": {"type": "string"},
          "retryable": {"type": "boolean"}, "details": {"type": "object"}, "request_id": {"type": "string"}
        }
      }
    }
  }
}
